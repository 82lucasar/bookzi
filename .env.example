# ============================================================
# Bookzi — Variables de entorno
# Copiá este archivo a .env.local y completá los valores
# NUNCA commitear .env.local ni .env
# ============================================================

# Base de datos — Neon PostgreSQL
# Obtener en: console.neon.tech → tu proyecto → Connection string
DATABASE_URL="postgresql://user:password@host/bookzi?sslmode=require"

# Redis — Upstash
# REST URL (para Next.js / serverless):  console.upstash.com → REST API
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxx"
# Redis URL (para BullMQ worker en Railway):  console.upstash.com → Details → Endpoint
UPSTASH_REDIS_URL="rediss://default:xxxxxxxx@xxx.upstash.io:6379"

# Auth — Supabase
# Obtener en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJxxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJxxxx"
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxxx"

# Email — Resend
# Obtener en: resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Bookzi <turnos@bookzi.app>"

# WhatsApp — Meta Cloud API (Fase 1: número compartido de Bookzi)
# Obtener en: developers.facebook.com → tu app → WhatsApp
WHATSAPP_ACCESS_TOKEN="EAAxxxx"
WHATSAPP_PHONE_NUMBER_ID="xxxxxxxxxx"
WHATSAPP_VERIFY_TOKEN="token-secreto-para-verificar-webhook"

# Sentry — Error tracking
# Obtener en: sentry.io → tu proyecto → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_DSN="https://xxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_ORG="bookzi"
SENTRY_PROJECT="bookzi-web"
# Obtener en: sentry.io → Settings → Auth Tokens (para source maps en CI)
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxx"

# Cron Secret (para proteger los endpoints de cron en API y web)
CRON_SECRET="un-string-secreto-largo-y-aleatorio"

# Mercado Pago (Fase 2)
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxx"
MERCADOPAGO_WEBHOOK_SECRET="xxxxxxxx"

# App
NODE_ENV="development"
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
